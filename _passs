#compdef passs
_passs() {
  if [[ ($words[2] == "tag" && $words[3] != "list") ||
        ($words[2] == "description" && ($words[3] != "get" || $CURRENT -eq 4)) ]]; then
    _files -W ~/.password-store -g "*.gpg(:r)"
  elif [[ $words[2] == "lint" ]]; then
    _arguments '3: :(--fix)'
  else
    words[1]=pass
    _pass
  fi
}
_passs "$@"
